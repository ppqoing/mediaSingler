<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|x64">
      <Configuration>Debug</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|x64">
      <Configuration>Release</Configuration>
      <Platform>x64</Platform>
    </ProjectConfiguration>
  </ItemGroup>

  <PropertyGroup Label="Globals">
    <VCProjectVersion>17.0</VCProjectVersion>
    <Keyword>Win32Proj</Keyword>
    <ProjectGuid>{B7A1C9D4-2F3E-4A6B-9C5D-1E2F3A4B5C6D}</ProjectGuid>
    <RootNamespace>VideoScGUI</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'" Label="Configuration">
    <ConfigurationType>Application</ConfigurationType>
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>v143</PlatformToolset>
    <WholeProgramOptimization>true</WholeProgramOptimization>
    <CharacterSet>Unicode</CharacterSet>
  </PropertyGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings" />
  <ImportGroup Label="PropertySheets">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>

  <PropertyGroup Label="UserMacros" />

  <PropertyGroup>
    <ProjectRoot>$(MSBuildThisFileDirectory)..\</ProjectRoot>
    <VcpkgEnabled>false</VcpkgEnabled>
    <VcpkgEnableManifest>false</VcpkgEnableManifest>
    <VcpkgTriplet Condition="'$(VcpkgTriplet)'==''">x64-windows</VcpkgTriplet>
    <VcpkgLibDir Condition="'$(Configuration)'=='Debug'">$(ProjectVcpkgInstalledDir)\$(VcpkgTriplet)\debug\lib</VcpkgLibDir>
    <VcpkgBinDir Condition="'$(Configuration)'=='Debug'">$(ProjectVcpkgInstalledDir)\$(VcpkgTriplet)\debug\bin</VcpkgBinDir>
    <RocksDbLibrary Condition="'$(Configuration)'=='Debug'">rocksdb-sharedd.lib</RocksDbLibrary>
    <RocksDbRuntime Condition="'$(Configuration)'=='Debug'">rocksdb-sharedd.dll</RocksDbRuntime>
    <ZlibRuntime Condition="'$(Configuration)'=='Debug'">zlibd1.dll</ZlibRuntime>
    <VcpkgLibDir Condition="'$(Configuration)'!='Debug'">$(ProjectVcpkgInstalledDir)\$(VcpkgTriplet)\lib</VcpkgLibDir>
    <VcpkgBinDir Condition="'$(Configuration)'!='Debug'">$(ProjectVcpkgInstalledDir)\$(VcpkgTriplet)\bin</VcpkgBinDir>
    <RocksDbLibrary Condition="'$(Configuration)'!='Debug'">rocksdb-shared.lib</RocksDbLibrary>
    <RocksDbRuntime Condition="'$(Configuration)'!='Debug'">rocksdb-shared.dll</RocksDbRuntime>
    <ZlibRuntime Condition="'$(Configuration)'!='Debug'">zlib1.dll</ZlibRuntime>
  </PropertyGroup>

  <!-- All output goes to solution-level $(Platform)\$(Configuration) -->
  <PropertyGroup>
    <OutDir>$(ProjectRoot)$(Platform)\$(Configuration)\</OutDir>
    <IntDir>$(Platform)\$(Configuration)\</IntDir>
  </PropertyGroup>

  <!-- ImGui sources live under third_party\imgui -->
  <PropertyGroup>
    <ImguiRoot>$(ProjectRoot)third_party\imgui</ImguiRoot>
    <VideoScRoot>$(ProjectRoot)VideoSc</VideoScRoot>
    <DiskInfoRoot>$(ProjectRoot)DiskInfo</DiskInfoRoot>
    <DedupCoreRoot>$(ProjectRoot)DedupCore</DedupCoreRoot>
    <EverythingSdkRoot>$(ProjectRoot)third_party\everything_sdk</EverythingSdkRoot>
    <FfmpegRoot>$(ProjectRoot)third_party\ffmpeg</FfmpegRoot>
    <OutRoot>$(ProjectRoot)$(Platform)\$(Configuration)</OutRoot>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <WarningLevel>Level3</WarningLevel>
      <SDLCheck>true</SDLCheck>
      <ConformanceMode>true</ConformanceMode>
      <LanguageStandard>stdcpp17</LanguageStandard>
      <AdditionalOptions>/utf-8 %(AdditionalOptions)</AdditionalOptions>
      <PreprocessorDefinitions>UNICODE;_UNICODE;NOMINMAX;WIN32_LEAN_AND_MEAN;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>
        $(ImguiRoot);
        $(ImguiRoot)\backends;
        $(VideoScRoot);
        $(DiskInfoRoot);
        $(DedupCoreRoot);
        $(EverythingSdkRoot)\include;
        $(FfmpegRoot)\include;
        %(AdditionalIncludeDirectories)
      </AdditionalIncludeDirectories>
      <DisableSpecificWarnings>4100;4189;4244;4267</DisableSpecificWarnings>
    </ClCompile>
    <Link>
      <SubSystem>Windows</SubSystem>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <AdditionalLibraryDirectories>$(FfmpegRoot)\lib;$(VcpkgLibDir);$(OutRoot);%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
      <AdditionalDependencies>d3d11.lib;d3dcompiler.lib;dxgi.lib;Dbghelp.lib;DiskInfo.lib;$(RocksDbLibrary);libmysql.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x64'">
    <ClCompile>
      <PreprocessorDefinitions>_DEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <Optimization>Disabled</Optimization>
    </ClCompile>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|x64'">
    <ClCompile>
      <PreprocessorDefinitions>NDEBUG;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
    </ClCompile>
    <Link>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
    </Link>
  </ItemDefinitionGroup>

  <!-- Sources -->
  <ItemGroup>
    <ClCompile Include="main.cpp" />
    <ClCompile Include="RenderBackend.cpp" />
    <ClCompile Include="VideoScApp.cpp" />
    <ClCompile Include="EverythingFileListQuery.cpp" />
    <ClCompile Include="diagnostics\CrashHandler.cpp" />
    <ClCompile Include="$(ImguiRoot)\imgui.cpp" />
    <ClCompile Include="$(ImguiRoot)\imgui_demo.cpp" />
    <ClCompile Include="$(ImguiRoot)\imgui_draw.cpp" />
    <ClCompile Include="$(ImguiRoot)\imgui_tables.cpp" />
    <ClCompile Include="$(ImguiRoot)\imgui_widgets.cpp" />
    <ClCompile Include="$(ImguiRoot)\backends\imgui_impl_win32.cpp" />
    <ClCompile Include="$(ImguiRoot)\backends\imgui_impl_dx11.cpp" />
  </ItemGroup>

  <ItemGroup>
    <ClInclude Include="EverythingFileListQuery.h" />
    <ClInclude Include="RenderBackend.h" />
    <ClInclude Include="VideoScApp.h" />
    <ClInclude Include="diagnostics\CrashHandler.h" />
  </ItemGroup>

  <!-- Reference VideoSc DLL and DiskInfo DLL (auto-links libs, builds dependency) -->
  <ItemGroup>
    <ProjectReference Include="..\VideoSc\VideoSc.vcxproj">
      <Project>{981fb139-7ea8-40c0-8734-00b41d1dcb3d}</Project>
    </ProjectReference>
    <ProjectReference Include="..\DiskInfo\DiskInfo.vcxproj">
      <Project>{c2d3e4f5-6789-4abc-def0-1234567890ab}</Project>
    </ProjectReference>
    <ProjectReference Include="..\DedupCore\DedupCore.vcxproj">
      <Project>{2a5519a0-7b18-47d6-9a21-52d58c1b9e10}</Project>
    </ProjectReference>
    <ProjectReference Include="..\VideoScCrashReporter\VideoScCrashReporter.vcxproj">
      <Project>{f6a7d537-44b6-4d31-b345-091c02a6739e}</Project>
      <LinkLibraryDependencies>false</LinkLibraryDependencies>
    </ProjectReference>
  </ItemGroup>

  <!-- Post-build: copy FFmpeg runtime DLLs + VideoSc.dll + DiskInfo.dll + Everything.exe + Everything64.dll -->
  <ItemDefinitionGroup>
    <PostBuildEvent>
      <Command>xcopy /d /y "$(FfmpegRoot)\bin\*.dll" "$(OutDir)" &gt;nul 2&gt;&amp;1
xcopy /d /y "$(OutRoot)\VideoSc.dll" "$(OutDir)" &gt;nul 2&gt;&amp;1
xcopy /d /y "$(OutRoot)\DiskInfo.dll" "$(OutDir)" &gt;nul 2&gt;&amp;1
copy /y "$(VcpkgBinDir)\libmysql.dll" "$(OutDir)" &gt;nul
copy /y "$(VcpkgBinDir)\$(RocksDbRuntime)" "$(OutDir)" &gt;nul
copy /y "$(VcpkgBinDir)\$(ZlibRuntime)" "$(OutDir)" &gt;nul
copy /y "$(VcpkgBinDir)\zstd.dll" "$(OutDir)" &gt;nul
copy /y "$(VcpkgBinDir)\libssl-3-x64.dll" "$(OutDir)" &gt;nul
copy /y "$(VcpkgBinDir)\libcrypto-3-x64.dll" "$(OutDir)" &gt;nul
if exist "$(ProjectVcpkgInstalledDir)\$(VcpkgTriplet)\tools\libmysql\mysqldump.exe" copy /y "$(ProjectVcpkgInstalledDir)\$(VcpkgTriplet)\tools\libmysql\mysqldump.exe" "$(OutDir)" &gt;nul
if exist "$(ProjectRoot)third_party\es" (
  if not exist "$(OutDir)third_party\es" mkdir "$(OutDir)third_party\es"
  xcopy /d /y "$(ProjectRoot)third_party\es\Everything.exe" "$(OutDir)third_party\es\" &gt;nul 2&gt;&amp;1
  xcopy /d /y "$(ProjectRoot)third_party\es\Everything.ini" "$(OutDir)third_party\es\" &gt;nul 2&gt;&amp;1
  xcopy /d /y "$(ProjectRoot)third_party\es\Everything.lng" "$(OutDir)third_party\es\" &gt;nul 2&gt;&amp;1
  xcopy /d /y "$(ProjectRoot)third_party\es\Everything.db" "$(OutDir)third_party\es\" &gt;nul 2&gt;&amp;1
  xcopy /d /y "$(ProjectRoot)third_party\es\Run History.csv" "$(OutDir)third_party\es\" &gt;nul 2&gt;&amp;1
)
if exist "$(ProjectRoot)third_party\everything_sdk\Everything64.dll" (
  if not exist "$(OutDir)third_party\everything_sdk" mkdir "$(OutDir)third_party\everything_sdk"
  xcopy /d /y "$(ProjectRoot)third_party\everything_sdk\Everything64.dll" "$(OutDir)third_party\everything_sdk\" &gt;nul 2&gt;&amp;1
)</Command>
    </PostBuildEvent>
  </ItemDefinitionGroup>

  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets" />
</Project>
