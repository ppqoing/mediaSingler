<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <!-- vcpkg 根目录：可用环境变量或 -p:VIDEOSC_VCPKG_ROOT=... 覆盖，缺省 E:\vcpkg。 -->
    <ProjectVcpkgRoot Condition="'$(VIDEOSC_VCPKG_ROOT)' != ''">$(VIDEOSC_VCPKG_ROOT)</ProjectVcpkgRoot>
    <ProjectVcpkgRoot Condition="'$(ProjectVcpkgRoot)' == ''">E:\vcpkg</ProjectVcpkgRoot>
    <ProjectVcpkgInstalledDir>$(ProjectVcpkgRoot)\installed</ProjectVcpkgInstalledDir>
  </PropertyGroup>
</Project>
